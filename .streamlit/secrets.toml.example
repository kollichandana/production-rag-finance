# Copy to .streamlit/secrets.toml and fill in for Streamlit Cloud deployment.
# DO NOT commit secrets.toml to git.

ANTHROPIC_API_KEY = "sk-ant-YOUR_KEY_HERE"

# Qdrant Cloud (free tier: https://cloud.qdrant.io)
QDRANT_URL = "https://your-cluster.qdrant.io"
QDRANT_API_KEY = "your-qdrant-cloud-key"
QDRANT_COLLECTION = "financial_filings"

GENERATION_MODEL = "claude-sonnet-4-6"
FALLBACK_MODEL = "claude-haiku-4-5-20251001"

# Optional observability
LANGFUSE_PUBLIC_KEY = ""
LANGFUSE_SECRET_KEY = ""
LANGFUSE_HOST = "https://cloud.langfuse.com"
